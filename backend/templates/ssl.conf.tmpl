{{- /* HTTPS/SSL Proxy Host Config */ -}}
upstream backend_{{ .Domain | printf "%s" }} {
    server {{ .ForwardHost }}:{{ .ForwardPort }};
    {{- if eq .LoadBalancing "least_conn" }}
    least_conn;
    {{- else if eq .LoadBalancing "consistent_hash" }}
    consistent_hash $request_uri;
    {{- end }}
    {{- if .HealthCheck }}

    check interval=3000 rise=2 fall=5 timeout=1000 type=http;
    check_http_send "HEAD / HTTP/1.0\r\nHost: {{ .Domain }}\r\n\r\n";
    check_http_expect_alive http_2xx http_3xx;
    {{- end }}
}

server {
    listen 80;
    server_name {{ .Domain }};

    location /.well-known/acme-challenge/ {
        root /etc/tengine/html;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    server_name {{ .Domain }};
    {{- if .AccessList }}
    {{- range .AccessList.ParsedRules }}

    {{ .Action }} {{ .IP }};
    {{- end }}
    deny all;
    {{- end }}

    {{- if .Certificate }}
    ssl_certificate {{ .Certificate.CertPath }};
    ssl_certificate_key {{ .Certificate.KeyPath }};
    {{- end }}

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;

    location / {
        proxy_pass {{ .ForwardScheme }}://backend_{{ .Domain }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
