{{- /* HTTP Proxy Host Config */ -}}
upstream backend_{{ .Domain | printf "%s" }} {
    server {{ .ForwardHost }}:{{ .ForwardPort }};
    {{- if eq .LoadBalancing "least_conn" }}
    least_conn;
    {{- else if eq .LoadBalancing "consistent_hash" }}
    consistent_hash $request_uri;
    {{- end }}
    {{- if .HealthCheck }}

    check interval=3000 rise=2 fall=5 timeout=1000 type=http;
    check_http_send "HEAD / HTTP/1.0\r\nHost: {{ .Domain }}\r\n\r\n";
    check_http_expect_alive http_2xx http_3xx;
    {{- end }}
}

server {
    listen 80;
    server_name {{ .Domain }};
    {{- if .AccessList }}
    {{- range .AccessList.ParsedRules }}

    {{ .Action }} {{ .IP }};
    {{- end }}
    deny all;
    {{- end }}

    location ^~ /.well-known/acme-challenge/ {
        allow all;
        root /etc/tengine/html;
    }

    location / {
        if ($cf_allow = 0) {
            return 403;
        }
        proxy_pass {{ .ForwardScheme }}://backend_{{ .Domain }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
